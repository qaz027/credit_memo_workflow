flowchart TD
    classDef llmFull fill:#2E7D32,stroke:#1B5E20,color:#fff,rx:4,ry:4
    classDef llmPartial fill:#E65100,stroke:#BF360C,color:#fff,rx:4,ry:4
    classDef llmNone fill:#C62828,stroke:#B71C1C,color:#fff,rx:4,ry:4
    classDef gate fill:#F9A825,stroke:#F57F17,color:#1a202c,font-weight:bold,rx:4,ry:4
    classDef decision fill:#1565C0,stroke:#0D47A1,color:#fff,rx:12,ry:12
    classDef endpoint fill:#6A1B9A,stroke:#4A148C,color:#fff,rx:20,ry:20
    classDef handoff fill:#4527A0,stroke:#311B92,color:#fff,rx:4,ry:4
    classDef futureUpgrade fill:#2E7D32,stroke:#1B5E20,color:#fff,rx:4,ry:4,stroke-width:3px,stroke-dasharray:5 5

    ENTER(["From Phase 6: Legal & Structural Analysis"]):::endpoint

    S7_1["7.1 Senior Analyst: Audit credit model for formula erro…"]:::llmFull
    ENTER --> S7_1
    HO_S7_1["HANDOFF -> Analyst | Artifact: Audit log"]:::handoff
    S7_1 --> HO_S7_1

    S7_2["7.2 Analyst: Verify all financial data against i…"]:::llmFull
    HO_S7_1 --> S7_2

    S7_3["7.3 Analyst: Validate all spread and pricing dat…"]:::llmPartial
    S7_2 --> S7_3

    S7_4["7.4 Legal Counsel: Validate covenant definitions again…"]:::llmPartial
    S7_3 --> S7_4
    D_S7_4{"Covenants match legal docs?"}:::decision
    S7_4 --> D_S7_4
    D_S7_4 -->|Mismatch -> Revise model, re-…| VARIANT_S7_4(["Variant"]):::endpoint
    D_S7_4 -->|Continue| CONT_S7_4[ ]

    S7_5["7.5 Analyst: Freeze data set and activate un-fre…"]:::llmNone
    CONT_S7_4 --> S7_5
    D_S7_5{"Data Freeze Gate passed?"}:::decision
    S7_5 --> D_S7_5
    D_S7_5 -->|Un-Freeze if spread moves >50…| VARIANT_S7_5(["Variant"]):::endpoint
    D_S7_5 -->|Continue| CONT_S7_5[ ]

    EXIT(["To Phase 8: Memo Drafting"]):::endpoint
    CONT_S7_5 --> EXIT

    %% ── LEGEND ──
    subgraph Legend
        direction LR
        LEG_F["Full LLM"]:::llmFull
        LEG_P["Partial / Paywall"]:::llmPartial
        LEG_N["Human Only"]:::llmNone
