    classDef endpoint fill:#6A1B9A,stroke:#4A148C,color:#fff,rx:20,ry:20

    %% ── ENTRY CONTEXT ──
    ENTRY_23([← Phases 2+3 Output: Industry context + financial analytics]):::endpoint
    ENTRY_4([← Phase 4 Output: Covenant quality, structural protections]):::endpoint

    ENTRY_23 --> S5_1_1

    subgraph PH5 ["Phase 5: Credit Modeling and Scenario Analysis"]
        subgraph S5_1 ["5.1 Pro Forma Analysis"]
            S5_1_1[5.1.1 - Analyst: Import Phase 3 financials and establish model template]:::llmPartial
            S5_1_1 --> S5_1_2[5.1.2 - Analyst: Build pro forma capital structure with new debt and sources and uses]:::llmPartial
            S5_1_2 --> S5_1_3[5.1.3 - Analyst: Calculate pro forma leverage, coverage, and liquidity at close]:::llmPartial
        end

        S5_1_OUT[Phase 5.1 Output: Pro forma cap structure, day-1 leverage, coverage, and liquidity]:::output
        S5_1_3 --> S5_1_OUT

        subgraph S5_2 ["5.2 Scenario Modeling"]
            S5_2_1[5.2.1 - Analyst: Develop base case operating assumptions]:::llmPartial
