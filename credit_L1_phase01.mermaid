---
title: "Credit — L1 Phase 1: Opportunity Screening & Mandate Fit"
---
flowchart TD
    classDef llmFull fill:#2E7D32,stroke:#1B5E20,color:#fff,rx:4,ry:4
    classDef llmPartial fill:#E65100,stroke:#BF360C,color:#fff,rx:4,ry:4
    classDef llmNone fill:#C62828,stroke:#B71C1C,color:#fff,rx:4,ry:4
    classDef gate fill:#F9A825,stroke:#F57F17,color:#1a202c,font-weight:bold,rx:4,ry:4
    classDef decision fill:#1565C0,stroke:#0D47A1,color:#fff,rx:12,ry:12
    classDef endpoint fill:#6A1B9A,stroke:#4A148C,color:#fff,rx:20,ry:20
    classDef handoff fill:#4527A0,stroke:#311B92,color:#fff,rx:4,ry:4
    classDef futureUpgrade fill:#2E7D32,stroke:#1B5E20,color:#fff,rx:4,ry:4,stroke-width:3px,stroke-dasharray:5 5

    ENTER(["Workflow Entry"]):::endpoint

    S1_1["1.1 Analyst: Confirm mandate fit and capital str… ^Future:Full"]:::futureUpgrade
    ENTER --> S1_1
    HO_S1_1["HANDOFF -> PM | Artifact: Mandate fit confirmation"]:::handoff
    S1_1 --> HO_S1_1

    S1_2["1.2 Analyst: Log opportunity in credit pipeline …"]:::llmPartial
    HO_S1_1 --> S1_2

    S1_3["1.3 Analyst: Screen credit metrics and pricing f…"]:::llmPartial
    S1_2 --> S1_3

    S1_4["1.4 Analyst: Review offering memorandum and cred…"]:::llmFull
    S1_3 --> S1_4

    S1_5["1.5 Compliance: Execute compliance check and MNPI w…"]:::llmNone
    S1_4 --> S1_5
    HO_S1_5["HANDOFF -> Analyst | Artifact: Clearance confirmation"]:::handoff
    S1_5 --> HO_S1_5

    S1_6["1.6 Analyst: Formulate preliminary credit thesis"]:::llmFull
    HO_S1_5 --> S1_6

    S1_7["1.7 Analyst: Identify top credit risks and key q…"]:::llmFull
    S1_6 --> S1_7

    S1_8["1.8 Analyst: Present credit screen to PM for res…"]:::llmNone
    S1_7 --> S1_8
    D_S1_8{"Go/No-Go: Allocate resources?"}:::decision
    S1_8 --> D_S1_8
    D_S1_8 -->|No-Go -> Pass, log reason| VARIANT_S1_8(["Variant"]):::endpoint
    D_S1_8 -->|Continue| CONT_S1_8[ ]

    EXIT(["To Phase 2: Issuer & Industry Analysis"]):::endpoint
    CONT_S1_8 --> EXIT

    %% ── LEGEND ──
    subgraph Legend
        direction LR
        LEG_F["Full LLM"]:::llmFull
        LEG_P["Partial / Paywall"]:::llmPartial
        LEG_N["Human Only"]:::llmNone
        LEG_U["Future: Full via free API"]:::futureUpgrade
    end