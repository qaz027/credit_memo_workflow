    classDef futureUpgrade fill:#2E7D32,stroke:#1B5E20,color:#fff,rx:4,ry:4,stroke-width:3px,stroke-dasharray:5 5

    ENTER(["From Phase 4: Credit Modeling & Scenarios"]):::endpoint

    S5_1["5.1 Analyst: Build comparable credit spread anal…"]:::llmPartial
