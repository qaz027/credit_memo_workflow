---
title: "Credit — L1 Phase 9: Quality Assurance & Review"
---
flowchart TD
    classDef llmFull fill:#2E7D32,stroke:#1B5E20,color:#fff,rx:4,ry:4
    classDef llmPartial fill:#E65100,stroke:#BF360C,color:#fff,rx:4,ry:4
    classDef llmNone fill:#C62828,stroke:#B71C1C,color:#fff,rx:4,ry:4
    classDef gate fill:#F9A825,stroke:#F57F17,color:#1a202c,font-weight:bold,rx:4,ry:4
    classDef decision fill:#1565C0,stroke:#0D47A1,color:#fff,rx:12,ry:12
    classDef endpoint fill:#6A1B9A,stroke:#4A148C,color:#fff,rx:20,ry:20
    classDef handoff fill:#4527A0,stroke:#311B92,color:#fff,rx:4,ry:4
    classDef futureUpgrade fill:#2E7D32,stroke:#1B5E20,color:#fff,rx:4,ry:4,stroke-width:3px,stroke-dasharray:5 5

    ENTER(["From Phase 8: Memo Drafting"]):::endpoint

    S9_1["9.1 Analyst: Check logical consistency across cr…"]:::llmFull
    ENTER --> S9_1

    S9_2["9.2 Analyst: Review downside rigor: is bear case…"]:::llmFull
    S9_1 --> S9_2

    S9_3["9.3 Analyst: Check formatting, grammar, and cove…"]:::llmFull
    S9_2 --> S9_3

    S9_4["9.4 Cold Reader: Commission cold read focused on 'Wh…"]:::llmPartial
    S9_3 --> S9_4
    D_S9_4{"Cold reader approves or sends back?"}:::decision
    S9_4 --> D_S9_4
    D_S9_4 -->|Sends back -> Analyst revises…| VARIANT_S9_4(["Variant"]):::endpoint
    D_S9_4 -->|Continue| CONT_S9_4[ ]

    S9_5["9.5 Analyst: Finalize memo and apply version sta…"]:::llmPartial
    CONT_S9_4 --> S9_5
    HO_S9_5["HANDOFF -> PM | Artifact: Final stamped memo"]:::handoff
    S9_5 --> HO_S9_5

    EXIT(["To Phase 10: IC Preparation & Execution"]):::endpoint
    HO_S9_5 --> EXIT

    %% ── LEGEND ──
    subgraph Legend
        direction LR
        LEG_F["Full LLM"]:::llmFull
        LEG_P["Partial / Paywall"]:::llmPartial
        LEG_N["Human Only"]:::llmNone
        LEG_U["Future: Full via free API"]:::futureUpgrade
    end